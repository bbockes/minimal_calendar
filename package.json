{
  "name": "minimal-calendar",
  "version": "1.0.0",
  "description": "Habit tracker and calendar — runs as desktop app with saved data",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "dev": "npx serve . -p 3000"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.minimal-calendar",
    "productName": "Minimal Calendar",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "calendar.html"],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": null
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip",  "arch": ["x64"] }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
